{
  "fmt": {
    "exclude": ["z-ai/"]
  },
  "lint": {
    "exclude": ["z-ai/"]
  },
  "tasks": {
    "dev": "deno run --watch --allow-read --allow-net --allow-env server.ts",
    "test": "deno test --allow-read --allow-env",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "ci": "deno lint && deno fmt --check && deno test --allow-read --allow-env"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@kawarimidoll/markup-tag": "jsr:@kawarimidoll/markup-tag@^1.0.1",
    "@deno/gfm": "jsr:@deno/gfm@^0.12"
  }
}
